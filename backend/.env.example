# Dashboard links + CORS. Local dev:
VIEW_BASE_URL=http://localhost:5173
# Production EC2 (must match Render VITE_APP_URL exactly):
# VIEW_BASE_URL=https://finsight-mcp-app.onrender.com

# MCP HTTP server (Cursor connects to this URL)
MCP_HOST=0.0.0.0
MCP_PORT=8080

# SEC EDGAR — required descriptive User-Agent (company name + contact email)
SEC_USER_AGENT=FinancialModelBuilder you@example.com

# Finnhub — free API key for comparative analysis market data (quote + profile)
FINNHUB_API_KEY=

# RAG — Postgres pgvector (optional; omit to keep file-only chunks.json)
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/fmb_rag

# RAG embeddings — switch provider without changing call sites
# EMBED_PROVIDER=huggingface   # default (or: openrouter)
# EMBED_BATCH_SIZE=            # optional override; default 32 (hf) / 64 (openrouter)
# EMBED_PARALLEL_BATCHES=4     # optional; max concurrent embed HTTP batches
# HF_TOKEN=                    # required for huggingface embed + rerank
# HF_EMBED_MODEL=BAAI/bge-base-en-v1.5
# OPENROUTER_API_KEY=
# OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# OPENROUTER_EMBED_DIMENSION=1536
# After switching to openrouter, run SQL in migrations/003_embed_1536_openrouter.sql
# then re-ingest 10-Ks.

# RAG rerank — switch provider without changing call sites (default: huggingface)
# RERANK_PROVIDER=huggingface   # or: openrouter
# HF_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5
# OPENROUTER_API_KEY=           # same key as embed when using openrouter rerank

# Session data retention (seconds). Default 3600 = 1 hour on AWS.
SESSION_TTL_SECONDS=3600

# Extra browser origins (comma-separated), only if needed beyond VIEW_BASE_URL
# CORS_ORIGINS=https://app.yourdomain.com
