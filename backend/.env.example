# Base URL for dashboard links returned by MCP tools
VIEW_BASE_URL=http://localhost:5173

# MCP HTTP server (Cursor connects to this URL)
MCP_HOST=0.0.0.0
MCP_PORT=8080

# SEC EDGAR — required descriptive User-Agent (company name + contact email)
SEC_USER_AGENT=FinancialModelBuilder you@example.com

# Session data retention (seconds). Default 3600 = 1 hour on AWS.
SESSION_TTL_SECONDS=3600

# Production EC2 (.env on server only — not committed):
# VIEW_BASE_URL=https://mcp-financial-model-builder.onrender.com
# MCP_HOST=0.0.0.0
# MCP_PORT=8080
